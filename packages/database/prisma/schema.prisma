generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_SHADOW_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, uuid_ossp(map: "uuid-ossp")]
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email           String    @unique
  githubId        String    @unique @map("github_id")
  githubUsername  String    @unique @map("github_username")
  displayName     String    @map("display_name")
  avatarUrl       String    @map("avatar_url")
  role            UserRole  @default(CONTRIBUTOR)
  isVerified      Boolean   @default(false) @map("is_verified")
  walletAddress   String?   @map("wallet_address")
  refreshToken    String?   @map("refresh_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  contributor     ContributorProfile?
  maintainedRepos Repository[]
  createdBounties Bounty[]            @relation("BountyCreator")
  notifications   Notification[]
  sessions        UserSession[]

  @@index([githubUsername])
  @@index([email])
  @@map("users")
}

model UserSession {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

enum UserRole {
  CONTRIBUTOR
  MAINTAINER
  ADMIN
}

// ============================================================
// CONTRIBUTOR PROFILE & REPUTATION
// ============================================================

model ContributorProfile {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  githubUsername      String    @unique @map("github_username")
  bio                 String?
  location            String?
  websiteUrl          String?   @map("website_url")
  twitterHandle       String?   @map("twitter_handle")
  skills              String[]
  reputationScore     Int       @default(0) @map("reputation_score")
  reputationTier      ReputationTier @default(NEWCOMER) @map("reputation_tier")
  totalEarned         Decimal   @default(0) @map("total_earned") @db.Decimal(18, 6)
  bountiesCompleted   Int       @default(0) @map("bounties_completed")
  bountiesAttempted   Int       @default(0) @map("bounties_attempted")
  avgDeliveryDays     Float?    @map("avg_delivery_days")
  githubStats         Json?     @map("github_stats")
  embedding           Unsupported("vector(1536)")?
  lastSyncedAt        DateTime? @map("last_synced_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBounties    Bounty[]          @relation("BountyAssignee")
  reputationEvents    ReputationEvent[]
  languageStats       LanguageStat[]
  ratings             ContributorRating[]
  pullRequests        PullRequest[]

  @@index([reputationScore(sort: Desc)])
  @@index([reputationTier])
  @@map("contributor_profiles")
}

model LanguageStat {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contributorId String             @map("contributor_id") @db.Uuid
  language      String
  level         ProficiencyLevel
  linesOfCode   BigInt             @default(0) @map("lines_of_code")
  repoCount     Int                @default(0) @map("repo_count")
  contributor   ContributorProfile @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@unique([contributorId, language])
  @@map("language_stats")
}

model ReputationEvent {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contributorId String             @map("contributor_id") @db.Uuid
  type          ReputationEventType
  delta         Int
  reason        String
  metadata      Json               @default("{}")
  createdAt     DateTime           @default(now()) @map("created_at")
  contributor   ContributorProfile @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@index([contributorId, createdAt(sort: Desc)])
  @@map("reputation_events")
}

model ContributorRating {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contributorId String             @map("contributor_id") @db.Uuid
  bountyId      String             @map("bounty_id") @db.Uuid
  raterId       String             @map("rater_id") @db.Uuid
  score         Int                // 1-5
  comment       String?
  createdAt     DateTime           @default(now()) @map("created_at")
  contributor   ContributorProfile @relation(fields: [contributorId], references: [id])
  bounty        Bounty             @relation(fields: [bountyId], references: [id])

  @@unique([contributorId, bountyId])
  @@map("contributor_ratings")
}

enum ReputationTier {
  NEWCOMER
  CONTRIBUTOR
  TRUSTED
  EXPERT
  ELITE
}

enum ReputationEventType {
  BOUNTY_COMPLETED
  BOUNTY_FAILED
  PR_MERGED
  PR_REJECTED
  DISPUTE_WON
  DISPUTE_LOST
  MAINTAINER_RATING
  EARLY_DELIVERY
  LATE_DELIVERY
  SPAM_DETECTED
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// ============================================================
// REPOSITORY
// ============================================================

model Repository {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  githubId        String    @unique @map("github_id")
  fullName        String    @unique @map("full_name")
  name            String
  owner           String
  description     String?
  url             String
  stars           Int       @default(0)
  forks           Int       @default(0)
  openIssues      Int       @default(0) @map("open_issues")
  language        String?
  languages       Json      @default("{}")
  topics          String[]
  isPrivate       Boolean   @default(false) @map("is_private")
  maintainerId    String    @map("maintainer_id") @db.Uuid
  healthScore     Float     @default(0) @map("health_score")
  embedding       Unsupported("vector(1536)")?
  lastAnalyzedAt  DateTime? @map("last_analyzed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  maintainer      User                    @relation(fields: [maintainerId], references: [id])
  bounties        Bounty[]
  intelligence    RepositoryIntelligence?

  @@index([fullName])
  @@index([maintainerId])
  @@index([stars(sort: Desc)])
  @@map("repositories")
}

model RepositoryIntelligence {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  repositoryId          String     @unique @map("repository_id") @db.Uuid
  codebaseComplexity    Float      @default(0) @map("codebase_complexity")
  testCoverage          Float?     @map("test_coverage")
  documentationScore    Float      @default(0) @map("documentation_score")
  activityScore         Float      @default(0) @map("activity_score")
  contributorDiversity  Float      @default(0) @map("contributor_diversity")
  issueResolutionTime   Float      @default(0) @map("issue_resolution_time")
  prMergeTime           Float      @default(0) @map("pr_merge_time")
  topContributors       String[]   @map("top_contributors")
  hotFiles              String[]   @map("hot_files")
  techStack             String[]   @map("tech_stack")
  aiSummary             String?    @map("ai_summary")
  recommendations       String[]
  analyzedAt            DateTime   @default(now()) @map("analyzed_at")
  repository            Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_intelligence")
}

// ============================================================
// BOUNTY
// ============================================================

model Bounty {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title           String
  description     String
  status          BountyStatus    @default(DRAFT)
  difficulty      BountyDifficulty
  category        BountyCategory
  amount          Decimal         @db.Decimal(18, 6)
  currency        String          @default("XLM")
  repositoryId    String          @map("repository_id") @db.Uuid
  issueNumber     Int?            @map("issue_number")
  issueUrl        String?         @map("issue_url")
  creatorId       String          @map("creator_id") @db.Uuid
  assigneeId      String?         @map("assignee_id") @db.Uuid
  tags            String[]
  expiresAt       DateTime?       @map("expires_at")
  onchainId       String?         @map("onchain_id")
  escrowAddress   String?         @map("escrow_address")
  txHash          String?         @map("tx_hash")
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  repository      Repository          @relation(fields: [repositoryId], references: [id])
  creator         User                @relation("BountyCreator", fields: [creatorId], references: [id])
  assignee        ContributorProfile? @relation("BountyAssignee", fields: [assigneeId], references: [id])
  milestones      BountyMilestone[]
  pullRequests    PullRequest[]
  disputes        Dispute[]
  escrowState     EscrowState?
  ratings         ContributorRating[]
  aiMatches       AIMatch[]

  @@index([status])
  @@index([repositoryId])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([amount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("bounties")
}

model BountyMilestone {
  id          String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bountyId    String          @map("bounty_id") @db.Uuid
  title       String
  description String
  amount      Decimal         @db.Decimal(18, 6)
  currency    String          @default("XLM")
  dueDate     DateTime?       @map("due_date")
  completedAt DateTime?       @map("completed_at")
  status      MilestoneStatus @default(PENDING)
  order       Int             @default(0)
  bounty      Bounty          @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@index([bountyId])
  @@map("bounty_milestones")
}

model EscrowState {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bountyId        String       @unique @map("bounty_id") @db.Uuid
  contractAddress String       @map("contract_address")
  fundedAmount    Decimal      @map("funded_amount") @db.Decimal(18, 6)
  releasedAmount  Decimal      @default(0) @map("released_amount") @db.Decimal(18, 6)
  currency        String       @default("XLM")
  status          EscrowStatus @default(UNFUNDED)
  fundTxHash      String?      @map("fund_tx_hash")
  releaseTxHash   String?      @map("release_tx_hash")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  bounty          Bounty       @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@map("escrow_states")
}

enum BountyStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  DISPUTED
  CANCELLED
  EXPIRED
}

enum BountyDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum BountyCategory {
  BUG_FIX
  FEATURE
  DOCUMENTATION
  SECURITY
  PERFORMANCE
  TESTING
  REFACTOR
  DESIGN
  DEVOPS
  OTHER
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISPUTED
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  PARTIALLY_RELEASED
  FULLY_RELEASED
  REFUNDED
  DISPUTED
}

// ============================================================
// PULL REQUESTS
// ============================================================

model PullRequest {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bountyId        String        @map("bounty_id") @db.Uuid
  contributorId   String        @map("contributor_id") @db.Uuid
  githubPrId      String        @map("github_pr_id")
  prNumber        Int           @map("pr_number")
  title           String
  url             String
  state           PRState       @default(OPEN)
  isMerged        Boolean       @default(false) @map("is_merged")
  mergedAt        DateTime?     @map("merged_at")
  isSpam          Boolean       @default(false) @map("is_spam")
  isDuplicate     Boolean       @default(false) @map("is_duplicate")
  qualityScore    Float?        @map("quality_score")
  verificationData Json?        @map("verification_data")
  commits         Int           @default(0)
  additions       Int           @default(0)
  deletions       Int           @default(0)
  changedFiles    Int           @default(0) @map("changed_files")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  bounty          Bounty             @relation(fields: [bountyId], references: [id])
  contributor     ContributorProfile @relation(fields: [contributorId], references: [id])

  @@unique([bountyId, githubPrId])
  @@index([bountyId])
  @@index([contributorId])
  @@map("pull_requests")
}

enum PRState {
  OPEN
  CLOSED
  MERGED
}

// ============================================================
// DISPUTES
// ============================================================

model Dispute {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bountyId    String        @map("bounty_id") @db.Uuid
  raisedById  String        @map("raised_by_id") @db.Uuid
  reason      String
  evidence    String?
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?     @map("resolved_at")
  resolvedById String?      @map("resolved_by_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  bounty      Bounty @relation(fields: [bountyId], references: [id])

  @@index([bountyId])
  @@index([status])
  @@map("disputes")
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CONTRIBUTOR
  RESOLVED_CREATOR
  RESOLVED_SPLIT
  DISMISSED
}

// ============================================================
// AI
// ============================================================

model AIMatch {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bountyId        String   @map("bounty_id") @db.Uuid
  contributorId   String   @map("contributor_id") @db.Uuid
  fitScore        Float    @map("fit_score")
  confidenceScore Float    @map("confidence_score")
  matchReasons    String[] @map("match_reasons")
  riskFactors     String[] @map("risk_factors")
  estimatedDays   Int?     @map("estimated_days")
  modelVersion    String   @map("model_version")
  computedAt      DateTime @default(now()) @map("computed_at")
  bounty          Bounty   @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@unique([bountyId, contributorId])
  @@index([bountyId, fitScore(sort: Desc)])
  @@map("ai_matches")
}

// ============================================================
// ANALYTICS
// ============================================================

model AnalyticsEvent {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type       String
  actorId    String?  @map("actor_id") @db.Uuid
  subjectId  String?  @map("subject_id")
  subjectType String? @map("subject_type")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([type, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("analytics_events")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String
  metadata  Json             @default("{}")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  BOUNTY_ASSIGNED
  BOUNTY_COMPLETED
  BOUNTY_CANCELLED
  PR_VERIFIED
  PAYOUT_RELEASED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  REPUTATION_MILESTONE
  AI_MATCH_FOUND
  SYSTEM
}
