# ============================================================
# AUTONOMOUS BOUNTY MARKETPLACE - Environment Configuration
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/bounty_marketplace"
DATABASE_SHADOW_URL="postgresql://postgres:password@localhost:5432/bounty_marketplace_shadow"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# --- Auth ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- GitHub OAuth ---
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"
GITHUB_APP_TOKEN="your-github-app-token"

# --- OpenAI ---
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_CHAT_MODEL="gpt-4o"

# --- Stellar / Soroban ---
STELLAR_NETWORK="testnet"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_ADMIN_SECRET_KEY="your-stellar-admin-secret-key"
BOUNTY_CONTRACT_ADDRESS="your-deployed-contract-address"
REPUTATION_CONTRACT_ADDRESS="your-deployed-reputation-contract-address"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Worker ---
WORKER_CONCURRENCY=5
WORKER_MAX_JOBS=100

# --- Analytics ---
POSTHOG_API_KEY="your-posthog-key"
POSTHOG_HOST="https://app.posthog.com"

# --- Email ---
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="your-resend-api-key"
EMAIL_FROM="noreply@bountyhub.dev"
